  "defaults": {
    "description": "Configured Indexer agent",
    "max_iterations": 20,
    "max_turns": 50,
    "required_paths": ["workspace"],
    "result_mappings": {
      "FAIL": {
        "default_jump": "abort",
        "exit_code": 10,
        "status": "failure"
      },
      "FIX": {
        "default_jump": "prev",
        "exit_code": 0,
        "status": "partial"
      },
      "PASS": {
        "default_jump": "next",
        "exit_code": 0,
        "status": "success"
      },
      "SKIP": {
        "default_jump": "next",
        "exit_code": 0,
        "status": "success"
      },
      "UNKNOWN": {
        "default_jump": "self",
        "exit_code": 1,
        "status": "unknown"
      }
    },
    "runtime": {
      "adapter": "codex",
      "mode": "app_server"
    },
    "timeout_seconds": 10800
  }
